# Application
SENTINEL_ENV=development
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinelbudget
POSTGRES_USER=sentinelbudget
POSTGRES_PASSWORD=change_me
POSTGRES_SSLMODE=prefer
POSTGRES_CONNECT_TIMEOUT=5

# Extensions
PGVECTOR_EXTENSION_NAME=vector

# Local LLM endpoint
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_CHAT_TIMEOUT_SECONDS=30
OLLAMA_CHAT_TEMPERATURE=0.0
AGENT_MAX_TOOL_HOPS=4
AGENT_HISTORY_LIMIT=40

# Proactive review daemon
REVIEW_DAILY_HOUR_UTC=7
REVIEW_WEEKLY_DAY_UTC=0
REVIEW_WEEKLY_HOUR_UTC=8
REVIEW_DAEMON_POLL_SECONDS=30
REVIEW_MEMORY_TOP_K=5

# Semantic memory embeddings
MEMORY_EMBEDDING_MODEL=nomic-embed-text:latest
MEMORY_EMBEDDING_DIM=768
MEMORY_EMBEDDING_TIMEOUT_SECONDS=30
MEMORY_DEFAULT_TOP_K=5
